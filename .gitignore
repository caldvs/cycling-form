# Credentials, env, secrets
# NOTE: blanket *.json — re-allow specific JSON via !path in later phases
*.json
.env
.env.*
# Re-allow committed example env templates
!.env.example
secrets/
*.pem
*.key

# Raw telemetry files contain GPS — never commit (BOOT-07)
*.fit
*.FIT
*.tcx
*.gpx

# Large media / derived artifacts — not for git
*.mp4
*.mov
*.avi
*.parquet

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/
.venv/
venv/

# Tool caches
.uv-cache/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
node_modules/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
