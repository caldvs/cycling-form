# ----------------------------------------------------------------------
# bootstrap-gcp.env.example — configuration template for bootstrap-gcp.sh
#
# Copy this file to `scripts/bootstrap-gcp.env` (gitignored via the
# top-level .gitignore's `.env*` pattern) and fill in the three blank
# user-supplied fields (GCP_PROJECT_ID, ALERT_EMAIL, BILLING_ACCOUNT_ID)
# before running ./scripts/bootstrap-gcp.sh.
#
# Per Phase 0 D-03: configuration values live here; the real .env file
# is gitignored. Per Phase 0 D-09 (Pitfall #13 — region mismatch): a
# SINGLE `GCP_REGION` variable is the source of truth for every GCP
# resource created by the bootstrap script.
#
# REGION OVERRIDE NOTE (D-10):
# If you are based in Europe/UK and add live demo links to your portfolio,
# switch GCP_REGION to europe-west1 BEFORE Phase 3 — region cannot be
# changed in-place after services are created.
# ----------------------------------------------------------------------

# Your GCP project id. Lowercase letters, digits, and hyphens; 6-30 chars.
# Example: vision-prod-2026
# Find existing: `gcloud projects list`
GCP_PROJECT_ID=

# Single source of truth for region (D-07, D-09).
# If you are based in Europe/UK and add live demo links to your portfolio,
# switch to europe-west1 BEFORE running this script. Region cannot be changed
# in place after services are created. (Phase 0 D-10.)
GCP_REGION=us-central1

# Multi-region location for BigQuery dataset. Aligns pricing with us-central1;
# switch to EU if GCP_REGION is europe-west1. (D-08.)
GCP_BQ_LOCATION=US

# Monthly budget in USD. The kill switch fires at 100% of this number.
# Phase 0 ships with $20; revisit only after Phase 5 deploys real services.
BUDGET_USD=20

# Display name for the GCP Billing budget. Used by gcloud to find/update.
BUDGET_DISPLAY_NAME=vision-monthly-budget

# Email that receives 50/90/100% budget alerts. Must be a valid Google account
# or have a Pub/Sub fallback wired separately.
ALERT_EMAIL=

# GCP billing account that funds the project.
# Run 'gcloud billing accounts list' to find this. Format: XXXXXX-XXXXXX-XXXXXX.
BILLING_ACCOUNT_ID=

# Pub/Sub topic the budget posts to AND the kill-switch Cloud Function
# subscribes to. Created by the bootstrap script if missing.
KILL_SWITCH_PUBSUB_TOPIC=vision-billing-alerts

# Deployed Cloud Function name. Matches the entry-point name in
# infra/kill-switch/main.py (`stop_billing`); the dashed form here is the
# Cloud Functions resource name, not the Python symbol.
KILL_SWITCH_FUNCTION_NAME=stop-billing

# Cloud Functions Gen 2 Python runtime. MediaPipe pins us to 3.12 elsewhere
# (per STACK.md and TC-3 in STATE.md), so we keep the kill switch on the
# same Python series for consistency.
KILL_SWITCH_RUNTIME=python312

# Kill switch deployed to the same region as the rest of the project (D-09).
# Do NOT introduce a second region here — Pitfall #13.
KILL_SWITCH_REGION=$GCP_REGION

# Short name of the service account that runs the kill-switch function.
# The full SA email is constructed in the script as
# ${KILL_SWITCH_SERVICE_ACCOUNT}@${GCP_PROJECT_ID}.iam.gserviceaccount.com
KILL_SWITCH_SERVICE_ACCOUNT=vision-killswitch-sa

# ----------------------------------------------------------------------
# USAGE:
#   1. cp scripts/bootstrap-gcp.env.example scripts/bootstrap-gcp.env
#   2. Fill in GCP_PROJECT_ID, ALERT_EMAIL, BILLING_ACCOUNT_ID.
#   3. (Optional) Override GCP_REGION before any service exists.
#   4. ./scripts/bootstrap-gcp.sh
# ----------------------------------------------------------------------
